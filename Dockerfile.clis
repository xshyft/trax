FROM golang:1.24 AS build
WORKDIR /src
COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -o /out/traxcli ./cmd/traxcli

FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y ca-certificates curl && rm -rf /var/lib/apt/lists/*
COPY --from=build /out/traxcli /usr/local/bin/traxcli
ENTRYPOINT ["/usr/local/bin/traxcli"]
